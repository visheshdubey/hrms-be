# PostgreSQL (local Docker — matches docker-compose.yml)
DATABASE_URL=postgresql://admin:password123@localhost:5432/hono_db

# Server
PORT=3000
JWT_SECRET=change-me-in-production

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,https://hrms.devcognito.tech

# Frontend URL (verification + password reset links)
FRONTEND_URL=http://localhost:5173

# Email (required for register / invite / forgot-password in production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=

# Optional: sourcing integrations
# PROXYCURL_API_KEY=
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_CX=
# GITHUB_TOKEN=

# Redis queue (email + upload tasks)
REDIS_URL=redis://localhost:6379
EMAIL_QUEUE_KEY=hrms:queue:email
EMAIL_DEAD_LETTER_KEY=hrms:queue:email:dead
UPLOAD_QUEUE_KEY=hrms:queue:upload
BATCH_KEY_PREFIX=hrms:batch:
QUEUE_MAX_EMAIL_ATTEMPTS=3
QUEUE_WORKER_POLL_SECONDS=2
QUEUE_BATCH_TTL_SECONDS=604800
ENABLE_QUEUE_WORKER=true
QUEUE_FALLBACK_INLINE_EMAIL=true
HEAVY_UPLOAD_BYTES=1048576
BULK_IMPORT_QUEUE_THRESHOLD=1
QUEUE_FALLBACK_INLINE_BULK_IMPORT=true

# Python ATS (hrms-py) — resume parse + job match score (Python only; Hono never extracts/scores)
# Local stub: http://127.0.0.1:3001  |  Full ML Docker: http://127.0.0.1:8000
ATS_API_URL=http://127.0.0.1:3001
# ATS_API_KEY=shared-secret-with-hrms-py

# BunnyCDN (optional — local disk used when unset)
# BUNNY_STORAGE_ZONE=
# BUNNY_STORAGE_ACCESS_KEY=
# BUNNY_CDN_URL=
# BUNNY_STORAGE_ENDPOINT=
# BUNNY_API_KEY=
