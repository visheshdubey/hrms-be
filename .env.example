# PostgreSQL (local Docker — matches docker-compose.yml)
DATABASE_URL=postgresql://admin:password123@localhost:5432/hono_db

# Server
PORT=3000
JWT_SECRET=change-me-in-production

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173

# Frontend URL (password reset emails)
FRONTEND_URL=http://localhost:5173

# Optional: email (SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# FROM_EMAIL=

# Optional: sourcing integrations
# PROXYCURL_API_KEY=
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_CX=
# GITHUB_TOKEN=
