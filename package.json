{
  "name": "hrms-be",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:push": "drizzle-kit push",
    "db:reset": "tsx src/db/reset-db.ts",
    "db:sync": "tsx src/db/migrate-portal-type.ts",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:users": "tsx src/db/seed-test-users.ts",
    "db:seed:stages": "tsx src/db/seed-stage-templates.ts",
    "db:seed:stress": "tsx src/db/seed-stress.ts",
    "db:seed:full": "tsx src/db/seed-faker-full.ts",
    "db:demo": "npm run db:reset && npm run db:push && npm run db:seed:full",
    "db:setup": "npm run db:push && npm run db:seed:full",
    "db:migrate:sqlite": "tsx src/db/migrate-sqlite-to-postgres.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/zod-validator": "^0.7.6",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^9.0.0",
    "pg": "^8.20.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.17",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "typescript": "^5.8.3"
  }
}
